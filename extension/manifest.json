{
  "manifest_version": 3,
  "name": "Trascrizione vocali WhatsApp",
  "version": "0.4.1",
  "description": "Trascrive i messaggi vocali visualizzati in WhatsApp Web.",
  "permissions": ["storage"],
  "host_permissions": [
    "https://web.whatsapp.com/*",
    "https://api.openai.com/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["page-bridge.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://web.whatsapp.com/*"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_title": "Trascrizione vocali WhatsApp",
    "default_popup": "popup.html"
  }
}
